@model RedZone.ViewModels.Prediction.PredictionCreateViewModel

@{
    ViewData["Title"] = "Make Prediction";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2>@ViewData["Title"]</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Validation Errors</h4>
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <form asp-controller="Prediction" asp-action="Create" method="post" class="mt-4">
                <input type="hidden" asp-for="MatchId" />

                <div class="mb-3">
                    <label class="form-label">Match</label>
                    <input class="form-control" value="@Model.HomeTeam vs @Model.AwayTeam" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="PredictedHomeGoals" class="form-label">Predicted Home Goals</label>
                    <input asp-for="PredictedHomeGoals" type="number" min="0" max="20" class="form-control" required />
                    <span asp-validation-for="PredictedHomeGoals" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PredictedAwayGoals" class="form-label">Predicted Away Goals</label>
                    <input asp-for="PredictedAwayGoals" type="number" min="0" max="20" class="form-control" required />
                    <span asp-validation-for="PredictedAwayGoals" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Predict</button>
                    <a asp-action="Index" asp-controller="Match" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}