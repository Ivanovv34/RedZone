@model RedZone.ViewModels.Prediction.PredictionCreateViewModel

@{
    ViewData["Title"] = "Make Prediction";
}

<div class="page-header">
    <h1 class="page-title">Make a <span>Prediction</span></h1>
    <a asp-action="Index" asp-controller="Match" class="btn btn-secondary btn-sm">← Back to Matches</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="prediction-form-card">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-3" role="alert">
                    <strong>Please fix the following:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <div class="match-banner">
                ⚽ @Model.HomeTeam <span style="color:rgba(255,255,255,0.5);font-size:1rem;"> vs </span> @Model.AwayTeam
            </div>

            <form asp-controller="Prediction" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MatchId" />

                <div class="row g-4 mb-4">
                    <div class="col-6">
                        <label asp-for="PredictedHomeGoals" class="form-label">@Model.HomeTeam Goals</label>
                        <input asp-for="PredictedHomeGoals"
                               type="number" min="0" max="20"
                               class="form-control form-control-lg text-center"
                               style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:0.05em;"
                               placeholder="0"
                               required />
                        <span asp-validation-for="PredictedHomeGoals" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="PredictedAwayGoals" class="form-label">@Model.AwayTeam Goals</label>
                        <input asp-for="PredictedAwayGoals"
                               type="number" min="0" max="20"
                               class="form-control form-control-lg text-center"
                               style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:0.05em;"
                               placeholder="0"
                               required />
                        <span asp-validation-for="PredictedAwayGoals" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        🎯 Submit Prediction
                    </button>
                    <a asp-action="Index" asp-controller="Match" class="btn btn-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
