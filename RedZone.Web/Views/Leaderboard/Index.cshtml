@model IEnumerable<RedZone.ViewModels.Prediction.LeaderboardEntryViewModel>

@{
    ViewData["Title"] = "Leaderboard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-light mb-0">🏆 Leaderboard</h1>
    </div>

    <div class="card bg-dark border-0 shadow-lg">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">
                    No scored predictions yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Total Points</th>
                            <th>Predictions</th>
                            <th>Exact Scores</th>
                            <th>Correct Results</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var entry in Model)
                        {
                            <tr>
                                <td>@entry.Position</td>
                                <td>@entry.UserName</td>
                                <td><strong>@entry.TotalPoints</strong></td>
                                <td>@entry.TotalPredictions</td>
                                <td>@entry.ExactScores</td>
                                <td>@entry.CorrectResults</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>