@model IEnumerable<RedZone.ViewModels.Match.MatchIndexViewModel>

@{
    ViewData["Title"] = "Matches";
}

<div class="page-header">
    <h1 class="page-title">Match<span>es</span></h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="btn btn-primary">+ Add Match</a>
    }
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>Home</th>
                <th>Away</th>
                <th>Date</th>
                <th>Competition</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                @await Html.PartialAsync("_MatchCardPartial", item)
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <div style="font-size:3rem;margin-bottom:1rem;">📅</div>
        <h3>No Matches Yet</h3>
        @if (User.IsInRole("Admin"))
        {
            <p>Start by adding the first match to the schedule.</p>
            <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="btn btn-primary mt-2">Add First Match</a>
        }
        else
        {
            <p>No scheduled matches are available at the moment.</p>
        }
    </div>
}