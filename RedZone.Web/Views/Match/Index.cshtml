@model IEnumerable<RedZone.ViewModels.Match.MatchIndexViewModel>

@{
    ViewData["Title"] = "Matches";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">Create New Match</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Home Team</th>
                        <th>Away Team</th>
                        <th>Match Date</th>
                        <th>Competition</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        @await Html.PartialAsync("_MatchCardPartial", item)
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No matches found. <a asp-action="Create">Create one now</a>
        </div>
    }
</div>
