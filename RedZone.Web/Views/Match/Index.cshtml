@model RedZone.ViewModels.Match.MatchIndexPageViewModel

@{
    ViewData["Title"] = "Matches";
}

<div class="page-header">
    <h1 class="page-title">Match<span>es</span></h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="btn btn-primary">+ Add Match</a>
    }
</div>

<form method="get" class="mb-4">
    <div class="d-flex gap-3 flex-wrap">
        <input type="text"
               name="searchTerm"
               value="@Model.Filter.SearchTerm"
               class="form-control"
               placeholder="Search by team..."
               style="max-width: 420px;" />

        <input type="text"
               name="competitionTerm"
               value="@Model.Filter.CompetitionTerm"
               class="form-control"
               placeholder="Search by competition..."
               style="max-width: 420px;" />
    </div>
</form>

@if (Model.Matches.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Home</th>
                    <th>Away</th>
                    <th>Date</th>
                    <th>Competition</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Matches)
                {
                    @await Html.PartialAsync("_MatchCardPartial", item)
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.Filter.SearchTerm"
                           asp-route-competitionTerm="@Model.Filter.CompetitionTerm">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchTerm="@Model.Filter.SearchTerm"
                               asp-route-competitionTerm="@Model.Filter.CompetitionTerm">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.Filter.SearchTerm"
                           asp-route-competitionTerm="@Model.Filter.CompetitionTerm">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="empty-state">
        <div style="font-size:3rem;margin-bottom:1rem;">📅</div>
        <h3>No Matches Yet</h3>

        @if (!string.IsNullOrWhiteSpace(Model.Filter.SearchTerm) ||
             !string.IsNullOrWhiteSpace(Model.Filter.CompetitionTerm))
        {
            <p>No matches found with the current filters.</p>
        }
        else if (User.IsInRole("Admin"))
        {
            <p>Start by adding the first match to the schedule.</p>
            <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="btn btn-primary mt-2">Add First Match</a>
        }
        else
        {
            <p>No scheduled matches are available at the moment.</p>
        }
    </div>
}

@section Scripts {
    <script>
        let matchSearchTimeout;

        document.querySelectorAll('input[name="searchTerm"], input[name="competitionTerm"]')
            .forEach(input => {
                input.addEventListener('input', function () {
                    clearTimeout(matchSearchTimeout);
                    matchSearchTimeout = setTimeout(() => {
                        this.form.submit();
                    }, 500);
                });
            });
    </script>
}