@model RedZone.ViewModels.Match.MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details";
}

<div class="page-header">
    <h1 class="page-title">Match <span>Details</span></h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Match" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">Edit</a>
            <a asp-area="Admin" asp-controller="Match" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">Delete</a>
        }
        <a asp-action="Index" class="btn btn-secondary btn-sm">← Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                @Model.HomeTeam vs @Model.AwayTeam
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-4">Home Team</dt>
                    <dd class="col-sm-8">@Model.HomeTeam</dd>

                    <dt class="col-sm-4">Away Team</dt>
                    <dd class="col-sm-8">@Model.AwayTeam</dd>

                    <dt class="col-sm-4">Match Date</dt>
                    <dd class="col-sm-8">@Model.MatchDate.ToString("dd MMMM yyyy, HH:mm")</dd>

                    <dt class="col-sm-4">Competition</dt>
                    <dd class="col-sm-8">
                        <span class="badge" style="background:rgba(200,16,46,0.15);color:var(--red);border:1px solid rgba(200,16,46,0.3);">
                            @Model.CompetitionName
                        </span>
                    </dd>
                </dl>

                <div class="mt-3">
                    <a asp-controller="Prediction"
                           asp-action="Create"
                           asp-route-matchId="@Model.Id"
                           class="btn btn-primary">
                        🎯 Make Prediction
                    </a>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                Comments
            </div>
            <div class="card-body">
                <form asp-controller="Comment" asp-action="Create" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input asp-for="NewComment.MatchId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="NewComment.Content" class="form-label">Add comment</label>
                        <textarea asp-for="NewComment.Content" class="form-control" rows="4" placeholder="Write your comment..."></textarea>
                        <span asp-validation-for="NewComment.Content" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>

                @if (!Model.Comments.Any())
                {
                    <div class="alert alert-info mb-0">
                        No comments yet. Be the first to comment.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="border rounded p-3 bg-dark-subtle">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong>@comment.UserName</strong>
                                        <div class="text-muted small">
                                            @comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                                        </div>
                                    </div>

                                    @if (comment.CanDelete)
                                    {
                                        <form asp-controller="Comment"
                                              asp-action="Delete"
                                              asp-route-id="@comment.Id"
                                              asp-route-matchId="@Model.Id"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </button>
                                        </form>
                                    }
                                </div>

                                <div style="white-space: pre-wrap;">@comment.Content</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}