@model RedZone.ViewModels.Match.MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details";
}

<div class="page-header">
    <h1 class="page-title">Match <span>Details</span></h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Match" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">Edit</a>
            <a asp-area="Admin" asp-controller="Match" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">Delete</a>
        }
        <a asp-action="Index" class="btn btn-secondary btn-sm">← Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">

        <!-- Match Info Card -->
        <div class="card">
            <div class="card-header">
                @Model.HomeTeam vs @Model.AwayTeam
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-4">Home Team</dt>
                    <dd class="col-sm-8">@Model.HomeTeam</dd>

                    <dt class="col-sm-4">Away Team</dt>
                    <dd class="col-sm-8">@Model.AwayTeam</dd>

                    <dt class="col-sm-4">Match Date</dt>
                    <dd class="col-sm-8">@Model.MatchDate.ToString("dd MMMM yyyy, HH:mm")</dd>

                    <dt class="col-sm-4">Competition</dt>
                    <dd class="col-sm-8">
                        <span class="comp-badge">@Model.CompetitionName</span>
                    </dd>
                </dl>

                <div class="mt-3">
                    <a asp-controller="Prediction"
                           asp-action="Create"
                           asp-route-matchId="@Model.Id"
                           class="btn btn-primary">
                        🎯 Make Prediction
                    </a>
                </div>
            </div>
        </div>

        <!-- Comments Card -->
        <div class="card mt-4">
            <div class="card-header">
                Comments
                @if (Model.Comments.Any())
                {
                    <span style="font-family:'Barlow',sans-serif; font-size:0.8rem; font-weight:400; color:var(--text-muted); margin-left:8px;">
                        @Model.Comments.Count()
                    </span>
                }
            </div>
            <div class="card-body p-4">

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-controller="Comment" asp-action="Create" method="post" class="mb-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MatchId" value="@Model.Id" />

                        <div class="mb-3">
                            <label for="Content" class="form-label">Add Comment</label>
                            <textarea name="Content"
                                      id="Content"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Write your comment..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-sm">Post Comment</button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info mb-4" style="font-size:0.9rem;">
                        <a asp-area="Identity" asp-page="/Account/Login" style="color:var(--gold);">Log in</a>
                        to post a comment.
                    </div>
                }

                @if (!Model.Comments.Any())
                {
                    <div style="text-align:center; padding:2rem 0; color:var(--text-muted);">
                        <div style="font-size:2rem; margin-bottom:0.5rem;">💬</div>
                        <div style="font-size:0.9rem;">No comments yet. Be the first!</div>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3" id="comments-list">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="comment-card">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="comment-author">@comment.UserName</div>
                                        <div class="comment-date">
                                            @comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                                        </div>
                                    </div>
                                    @if (comment.CanDelete)
                                    {
                                        <form asp-controller="Comment"
                                              asp-action="Delete"
                                              asp-route-id="@comment.Id"
                                              asp-route-matchId="@Model.Id"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    }
                                </div>
                                <div class="comment-content">@comment.Content</div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}