@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">

        <div style="font-size:5rem; margin-bottom:1rem; line-height:1;">⚠️</div>

        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:5rem; letter-spacing:0.05em; color:var(--red); margin-bottom:0;">
            Oops!
        </h1>

        <p style="color:var(--text-muted); font-size:1.1rem; margin-bottom:2rem;">
            Something went wrong while processing your request.
        </p>

        @if (Model?.ShowRequestId == true)
        {
            <div class="alert alert-danger mb-3" style="font-family:'Barlow Condensed',sans-serif; font-size:0.85rem; letter-spacing:0.05em;">
                <strong>Request ID:</strong>
                <code style="background:rgba(255,255,255,0.08); padding:2px 6px; border-radius:4px; color:var(--text);">
                    @Model.RequestId
                </code>
            </div>
        }

        <div class="card mb-4" style="text-align:left;">
            <div class="card-body p-4">
                <h5 style="font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:0.05em; color:var(--white); margin-bottom:0.75rem;">
                    Running Locally?
                </h5>
                <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:0;">
                    Set <code style="background:rgba(255,255,255,0.08); padding:2px 6px; border-radius:4px; color:var(--text);">ASPNETCORE_ENVIRONMENT</code>
                    to <strong style="color:var(--white);">Development</strong> in your launch settings to see the full exception details.
                </p>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                ← Back to Home
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                Go Back
            </a>
        </div>

    </div>
</div>
