@model RedZone.ViewModels.Match.MatchIndexViewModel

<tr>
    <td style="font-weight:600; color:var(--white);">@Model.HomeTeam</td>
    <td style="font-weight:600; color:var(--white);">@Model.AwayTeam</td>
    <td style="color:var(--text-muted); font-size:0.9rem;">
        @Model.MatchDate.ToString("dd MMM yyyy")
        <span style="opacity:0.6; margin-left:4px;">@Model.MatchDate.ToString("HH:mm")</span>
    </td>
    <td>
        <span class="comp-badge">@Model.CompetitionName</span>
    </td>
    <td class="text-end" style="white-space:nowrap;">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-info">Details</a>
        }
        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Match" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning">Edit</a>
            <a asp-area="Admin" asp-controller="Match" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-danger">Delete</a>
        }
        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (Model.HasPredicted)
            {
                <span class="btn btn-sm btn-secondary disabled">✓ Predicted</span>
            }
            else
            {
                <a asp-controller="Prediction"
                   asp-action="Create"
                   asp-route-matchId="@Model.Id"
                   class="btn btn-success btn-sm">Predict</a>
            }
        }
    </td>
</tr>