@model IEnumerable<RedZone.ViewModels.Competition.CompetitionViewModel>

@{
    ViewData["Title"] = "Competitions";
}

<div class="page-header">
    <h1 class="page-title">Competi<span>tions</span></h1>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>Competition</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <span class="comp-icon">🏆</span>
                        <strong style="color:var(--white);">@item.Name</strong>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <div style="font-size:3rem;margin-bottom:1rem;">🏆</div>
        <h3>No Competitions Yet</h3>
        <p>Competitions will appear here once they are added.</p>
    </div>
}