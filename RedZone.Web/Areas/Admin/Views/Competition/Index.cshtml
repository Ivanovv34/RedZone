@model IEnumerable<RedZone.ViewModels.Competition.CompetitionViewModel>

@{
    ViewData["Title"] = "Manage Competitions";
}

<div class="page-header">
    <h1 class="page-title">Competi<span>tions</span></h1>
    <a asp-area="Admin" asp-controller="Competition" asp-action="Create" class="btn btn-primary">+ Add Competition</a>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>Competition</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <span class="comp-icon">🏆</span>
                        <strong style="color:var(--white);">@item.Name</strong>
                    </td>
                    <td class="text-end" style="white-space:nowrap;">
                        <a asp-area="Admin" asp-controller="Competition" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-area="Admin" asp-controller="Competition" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <div style="font-size:3rem;margin-bottom:1rem;">🏆</div>
        <h3>No Competitions Yet</h3>
        <p>Add a competition to get started organising matches.</p>
        <a asp-area="Admin" asp-controller="Competition" asp-action="Create" class="btn btn-primary mt-2">Add Competition</a>
    </div>
}