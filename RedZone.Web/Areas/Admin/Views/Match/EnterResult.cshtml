@model RedZone.ViewModels.Match.EnterMatchResultViewModel

@{
    ViewData["Title"] = "Enter Match Result";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@ViewData["Title"]</h1>

            <div class="alert alert-info mt-3">
                <strong>@Model.HomeTeam</strong> vs <strong>@Model.AwayTeam</strong>
            </div>

            <form asp-area="Admin" asp-controller="Match" asp-action="EnterResult" asp-route-id="@Model.MatchId" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MatchId" />
                <input type="hidden" asp-for="HomeTeam" />
                <input type="hidden" asp-for="AwayTeam" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HomeGoals" class="form-label"></label>
                        <input asp-for="HomeGoals" class="form-control" />
                        <span asp-validation-for="HomeGoals" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="AwayGoals" class="form-label"></label>
                        <input asp-for="AwayGoals" class="form-control" />
                        <span asp-validation-for="AwayGoals" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Save Result</button>
                    <a asp-area="Admin" asp-controller="Match" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}