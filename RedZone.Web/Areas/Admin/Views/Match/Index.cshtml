@model RedZone.ViewModels.Match.MatchIndexPageViewModel

@{
    ViewData["Title"] = "Manage Matches";
}

<div class="page-header">
    <h1 class="page-title">Manage <span>Matches</span></h1>
    <a asp-action="Create" class="btn btn-primary">+ Add Match</a>
</div>

@if (Model.Matches.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Home</th>
                    <th>Away</th>
                    <th>Date</th>
                    <th>Competition</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Matches)
                {
                    <tr>
                        <td>@item.HomeTeam</td>
                        <td>@item.AwayTeam</td>
                        <td>@item.MatchDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@item.CompetitionName</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            <a asp-action="EnterResult" asp-route-id="@item.Id" class="btn btn-sm btn-success">Result</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="empty-state">
        <h3>No Matches Yet</h3>
        <a asp-action="Create" class="btn btn-primary mt-2">Add First Match</a>
    </div>
}