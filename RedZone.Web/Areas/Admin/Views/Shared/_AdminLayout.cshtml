<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RedZone Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">RedZone Admin</a>

            <div class="navbar-nav">
                <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Competition" asp-action="Index">Competitions</a>
                <a class="nav-link" asp-area="" asp-controller="Match" asp-action="Index">Matches</a>
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Back to Site</a>
            </div>
        </div>
    </nav>
</header>

<main class="py-4">
    @RenderBody()
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>